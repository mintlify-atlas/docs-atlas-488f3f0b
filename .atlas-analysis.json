            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "QR code and OTP (phone number pairing) authentication",
    "Automatic session persistence via SQLite",
    "Built-in command routing with configurable prefix",
    "Message reply, react, read, delete, and edit helpers",
    "Media message downloading",
    "JID ↔ phone-number resolution cache",
    "Message cache with configurable TTL for retry support",
    "Group metadata cache with TTL",
    "Automatic reconnection with exponential back-off",
    "Typed wrapper over the Baileys WebSocket"
  ],
  "publicApiSurface": [

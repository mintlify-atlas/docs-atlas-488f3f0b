{
  "projectType": "sdk-library",
  "projectName": "WABotJS",
  "projectDescription": "A TypeScript SDK for building WhatsApp bots on top of Baileys, with built-in authentication, message handling, command routing, and SQLite-backed caching.",
  "theme": "luma",
  "primaryColor": "#25D366",
  "lightColor": "#DCF8C6",
  "darkColor": "#075E54",
